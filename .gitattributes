# Normalize line endings for all text files
* text=auto

# Force LF line endings for specific file types
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.py text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.safetensors binary
*.gguf binary
*.bin binary
*.ckpt binary
*.pth binary
*.onnx binary
*.mlmodel binary
*.tflite binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
