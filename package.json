{
  "name": "up-take",
  "version": "0.1.0",
  "description": "AI-powered screen intelligence overlay for Windows. Capture, OCR, understand — locally.",
  "type": "module",
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "tauri": "tauri"
  },
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
